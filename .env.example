# ============================================================
# NKP Workshop Platform — Environment Variables
# Copy to .env and fill in values before running.
# DRY_RUN=true is safe for local development (no cluster needed).
# ============================================================

# --- Database ---
DATABASE_URL=sqlite:///./data/lab-manager.db

# --- Cluster ---
KUBECONFIG_PATH=                    # Empty = use default ~/.kube/config
CLUSTER_CONTEXT=nkp-workshop        # kubectl context name

# --- Dry Run ---
# When true: provisioner logs actions without executing; generates fake URLs.
# Default true — set to false only when connected to a real cluster + Educates.
DRY_RUN=true

# --- Registration App ---
ADMIN_PASSWORD=                     # Empty = no auth (dev only). Set for production.
APP_PORT=8000
APP_TITLE=NKP Partner Workshop

# --- Educates ---
EDUCATES_PORTAL_URL=https://educates.nkp-lab.local
EDUCATES_PORTAL_PASSWORD=           # From Educates installation output

# --- NUS / S3 (for NUS course exercises) ---
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Harbor Registry (for Developer track) ---
HARBOR_URL=
HARBOR_PROJECT=workshop

# --- GitLab (for Developer track CI/CD) ---
GITLAB_URL=

# --- Branding ---
APP_TITLE=NKP Partner Workshop
